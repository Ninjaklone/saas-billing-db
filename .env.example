# NOT the actual .env file. Exists solely for examples.
# You can copy this to the .env (gitignored) and fill in your values.
# .env is read automatically by `docker compose`. Obviously you don't commit that.

# --- Billing source database (the existing saas-billing-db Postgres instance) ---
# This is wherever tenants/invoices/etc. already live. In Codespaces this is almost
# certainly NOT localhost, since the Codespace is a separate machine from your PC.
# See docs/dev_environment_setup.md, "Where does the billing Postgres actually run?"
# You decide this one.
BILLING_DB_HOST=
BILLING_DB_PORT=5432
BILLING_DB_NAME=saas_billing
BILLING_DB_USER=
BILLING_DB_PASSWORD=

# --- AWS (raw landing zone target for Phase 11, I chose to use RDS) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
S3_RAW_LANDING_BUCKET=
